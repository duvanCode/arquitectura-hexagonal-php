# ── Base de Datos ──────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=crud_usuarios
DB_USER=appuser
DB_PASSWORD=cambia_esta_password
DB_CHARSET=utf8mb4

# ── Base de Datos (solo para Docker / Seeder) ───────────────────────────────
DB_ROOT_USER=root
DB_ROOT_PASSWORD=cambia_esta_root_password

# ── Docker ───────────────────────────────────────────────────────────────────
APP_PORT=8080
# Poner en true solo en el primer despliegue para crear tablas y usuario admin
RUN_SEEDER=false

# ── SMTP ───────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu@correo.com
MAIL_PASSWORD=tu_contrasena_de_aplicacion
MAIL_FROM=tu@correo.com
MAIL_FROM_NAME="CRUD Usuarios"
MAIL_ENCRYPTION=tls
